index 0000000..15dc4e5
--- /dev/null
+++ b/drivers/telescope/lx200_OnStepX.cpp
@@ -0,0 +1,426 @@
+/*
+    LX200 OnStepX
+
+    Custom INDI device name for the PiFinder OnStep integration.
+*/
+
+#include "lx200_OnStepX.h"
+
+#include <cmath>
+#include <ctime>
+
+namespace
+{
+constexpr int GUIDE_RATE_WE_INDEX = 0;
+constexpr int GUIDE_RATE_NS_INDEX = 1;
+constexpr double GUIDE_RATE_TOLERANCE = 0.05;
+
+bool closeTo(double a, double b)
+{
+    return std::fabs(a - b) < 0.01;
+}
+
+int guideRateSelectForMultiplier(double rate)
+{
+    if (closeTo(rate, 0.25))
+        return 0;
+    if (closeTo(rate, 0.5))
+        return 1;
+    if (closeTo(rate, 1.0))
+        return 2;
+    if (closeTo(rate, 2.0))
+        return 3;
+    if (closeTo(rate, 4.0))
+        return 4;
+    if (closeTo(rate, 8.0))
+        return 5;
+    if (closeTo(rate, 20.0))
+        return 6;
+    if (closeTo(rate, 48.0))
+        return 7;
+    if (rate >= 72.0 && rate < 180.0)
+        return 8;
+    if (rate >= 180.0)
+        return 9;
+    return -1;
+}
+
+}
+
+LX200_OnStepX::LX200_OnStepX()
+{
+    configureGuideRateProperty();
+}
+
+void LX200_OnStepX::configureGuideRateProperty()
+{
+    GuideRateNP[GUIDE_RATE_WE_INDEX].setMinMax(0.25, 240.0);
+    GuideRateNP[GUIDE_RATE_WE_INDEX].setStep(0.25);
+    GuideRateNP[GUIDE_RATE_NS_INDEX].setMinMax(0.25, 240.0);
+    GuideRateNP[GUIDE_RATE_NS_INDEX].setStep(0.25);
+    GuideRateNP.setPermission(IP_RW);
+}
+
+const char *LX200_OnStepX::getDefaultName()
+{
+    return "LX200 OnStepX";
+}
+
+bool LX200_OnStepX::initProperties()
+{
+    const bool result = LX200_OnStep::initProperties();
+    configureGuideRateProperty();
+    return result;
+}
+
+bool LX200_OnStepX::ISNewNumber(const char *dev, const char *name, double values[], char *names[], int n)
+{
+    if (dev != nullptr && strcmp(dev, getDeviceName()) == 0 && GuideRateNP.isNameMatch(name))
+    {
+        double guide_we = GuideRateNP[GUIDE_RATE_WE_INDEX].getValue();
+        double guide_ns = GuideRateNP[GUIDE_RATE_NS_INDEX].getValue();
+
+        for (int i = 0; i < n; i++)
+        {
+            if (GuideRateNP[GUIDE_RATE_WE_INDEX].isNameMatch(names[i]))
+                guide_we = values[i];
+            else if (GuideRateNP[GUIDE_RATE_NS_INDEX].isNameMatch(names[i]))
+                guide_ns = values[i];
+        }
+
+        if (guide_we <= 0.0 || guide_ns <= 0.0)
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOG_ERROR("OnStepX guide rate invalid; expected positive sidereal multipliers.");
+            return false;
+        }
+
+        if (!closeTo(guide_we, guide_ns))
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOG_ERROR("OnStepX pulse guide rate is a shared OnStep setting; W/E and N/S rates must match.");
+            return false;
+        }
+
+        char cmd[CMD_MAX_LEN] = {0};
+        const int rate_select = guideRateSelectForMultiplier(guide_we);
+        if (rate_select < 0)
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOGF_ERROR("Unsupported OnStepX pulse guide rate %.2fx.", guide_we);
+            return false;
+        }
+
+        snprintf(cmd, sizeof(cmd), ":R%d#", rate_select);
+        if (!sendOnStepCommandBlind(cmd))
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOGF_ERROR("Error setting OnStepX pulse guide rate selector %d.", rate_select);
+            return false;
+        }
+
+        const struct timespec timeout = {0, 100000000L};
+        nanosleep(&timeout, nullptr);
+
+        double actual_rate = 0.0;
+        char guide_response[RB_MAX_LEN] = {0};
+        if (getCommandDoubleResponse(PortFD, &actual_rate, guide_response, ":GX90#") <= 1)
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOG_ERROR("Could not read OnStepX pulse guide rate after setting GUIDE_RATE.");
+            return false;
+        }
+
+        GuideRateNP[GUIDE_RATE_WE_INDEX].setValue(actual_rate);
+        GuideRateNP[GUIDE_RATE_NS_INDEX].setValue(actual_rate);
+        if (std::fabs(actual_rate - guide_we) > GUIDE_RATE_TOLERANCE)
+        {
+            GuideRateNP.setState(IPS_ALERT);
+            GuideRateNP.apply();
+            LOGF_ERROR("OnStepX pulse guide rate request %.2fx was not applied; device reports %.2fx.",
+                       guide_we, actual_rate);
+            return false;
+        }
+
+        GuideRateNP.setState(IPS_OK);
+        GuideRateNP.apply();
+        LOGF_INFO("OnStepX pulse guide rate set to selector %d (%.2fx sidereal).", rate_select, actual_rate);
+        return true;
+    }
+
+    if (dev != nullptr && strcmp(dev, getDeviceName()) == 0 && BacklashNP.isNameMatch(name))
+    {
+        int nset = 0;
+        double backlash_dec = BacklashNP[0].getValue();
+        double backlash_ra = BacklashNP[1].getValue();
+
+        for (int i = 0; i < n; i++)
+        {
+            if (BacklashNP[0].isNameMatch(names[i]))
+            {
+                backlash_dec = values[i];
+                LOGF_DEBUG("===CMD==> OnStepX Backlash DEC= %f", backlash_dec);
+                nset += backlash_dec >= 0 && backlash_dec <= 3600;
+            }
+            else if (BacklashNP[1].isNameMatch(names[i]))
+            {
+                backlash_ra = values[i];
+                LOGF_DEBUG("===CMD==> OnStepX Backlash RA= %f", backlash_ra);
+                nset += backlash_ra >= 0 && backlash_ra <= 3600;
+            }
+        }
+
+        if (nset != 2)
+        {
+            BacklashNP.setState(IPS_ALERT);
+            BacklashNP.apply();
+            LOG_ERROR("OnStepX Backlash invalid; expected RA/DEC in range 0..3600 arc-sec.");
+            return false;
+        }
+
+        char cmd[CMD_MAX_LEN] = {0};
+        snprintf(cmd, sizeof(cmd), ":$BD%d#", static_cast<int>(backlash_dec));
+        if (sendOnStepCommand(cmd))
+        {
+            BacklashNP.setState(IPS_ALERT);
+            BacklashNP.apply();
+            LOG_ERROR("Error setting OnStepX Backlash DEC.");
+            return false;
+        }
+
+        const struct timespec timeout = {0, 100000000L};
+        nanosleep(&timeout, nullptr);
+
+        snprintf(cmd, sizeof(cmd), ":$BR%d#", static_cast<int>(backlash_ra));
+        if (sendOnStepCommand(cmd))
+        {
+            BacklashNP.setState(IPS_ALERT);
+            BacklashNP.apply();
+            LOG_ERROR("Error setting OnStepX Backlash RA.");
+            return false;
+        }
+
+        BacklashNP[0].setValue(backlash_dec);
+        BacklashNP[1].setValue(backlash_ra);
+        BacklashNP.setState(IPS_OK);
+        BacklashNP.apply();
+        return true;
+    }
+
+    return LX200_OnStep::ISNewNumber(dev, name, values, names, n);
+}
+
+bool LX200_OnStepX::updateLocation(double latitude, double longitude, double elevation)
+{
+    if (isSimulation())
+        return true;
+
+    // INDI stores longitude as cartographic east-positive degrees. OnStep LX200
+    // follows the Meade convention used by its web UI: east is negative and
+    // west is positive.
+    double onstep_long = longitude;
+    while (onstep_long < 0)
+        onstep_long += 360;
+    while (onstep_long >= 360)
+        onstep_long -= 360;
+    if (onstep_long > 180)
+        onstep_long = 360 - onstep_long;
+    else if (onstep_long > 0)
+        onstep_long *= -1;
+
+    if (setSiteLongitude(PortFD, onstep_long) < 0)
+    {
+        LOG_ERROR("Error setting site longitude coordinates");
+        return false;
+    }
+
+    if (setSiteLatitude(PortFD, latitude) < 0)
+    {
+        LOG_ERROR("Error setting site latitude coordinates");
+        return false;
+    }
+
+    if (setSiteElevation(PortFD, elevation) < 0)
+    {
+        LOG_ERROR("Error setting site elevation");
+        return false;
+    }
+
+    char lat_text[32] = {0}, lon_text[32] = {0};
+    fs_sexa(lat_text, latitude, 3, 360000);
+    fs_sexa(lon_text, longitude, 4, 360000);
+
+    LOGF_INFO("Site location updated to Lat %.32s - Long %.32s - Elev %.1fm", lat_text, lon_text, elevation);
+
+    return true;
+}
+
+int LX200_OnStepX::setSiteLongitude(int fd, double longitude)
+{
+    int degrees = 0, minutes = 0;
+    double seconds_fraction = 0.0;
+    char command[32] = {0};
+
+    getSexComponentsIID(longitude, &degrees, &minutes, &seconds_fraction);
+    if (OSHighPrecision)
+    {
+        int seconds = static_cast<int>(std::round(seconds_fraction));
+        if (seconds >= 60)
+        {
+            seconds = 0;
+            minutes += 1;
+            if (minutes >= 60)
+            {
+                minutes = 0;
+                degrees += degrees >= 0 ? 1 : -1;
+            }
+        }
+        snprintf(command, sizeof(command), ":Sg%+04d*%02d:%02d#", degrees, minutes, seconds);
+        int result = setStandardProcedure(fd, command);
+        if (result == 0)
+            return 0;
+
+        snprintf(command, sizeof(command), ":Sg%+04d*%02d#", degrees, minutes);
+        return setStandardProcedure(fd, command);
+    }
+
+    snprintf(command, sizeof(command), ":Sg%+04d*%02d#", degrees, minutes);
+    return setStandardProcedure(fd, command);
+}
+
+int LX200_OnStepX::setSiteLatitude(int fd, double latitude)
+{
+    int degrees = 0, minutes = 0;
+    double seconds_fraction = 0.0;
+    char command[32] = {0};
+
+    getSexComponentsIID(latitude, &degrees, &minutes, &seconds_fraction);
+    if (OSHighPrecision)
+    {
+        int seconds = static_cast<int>(std::round(seconds_fraction));
+        if (seconds >= 60)
+        {
+            seconds = 0;
+            minutes += 1;
+            if (minutes >= 60)
+            {
+                minutes = 0;
+                degrees += degrees >= 0 ? 1 : -1;
+            }
+        }
+        snprintf(command, sizeof(command), ":St%+03d*%02d:%02d#", degrees, minutes, seconds);
+        int result = setStandardProcedure(fd, command);
+        if (result == 0)
+            return 0;
+
+        snprintf(command, sizeof(command), ":St%+03d*%02d#", degrees, minutes);
+        return setStandardProcedure(fd, command);
+    }
+
+    snprintf(command, sizeof(command), ":St%+03d*%02d#", degrees, minutes);
+    return setStandardProcedure(fd, command);
+}
+
+int LX200_OnStepX::setSiteElevation(int fd, double elevation)
+{
+    char command[32] = {0};
+
+    snprintf(command, sizeof(command), ":Sv%g#", elevation);
+    return setStandardProcedure(fd, command);
+}
+
+bool LX200_OnStepX::getOnStepSiteCoordinate(int fd, const char *cmd, double *value, bool longitude)
+{
+    char response[RB_MAX_LEN] = {0};
+    int result = getCommandSingleCharErrorOrLongResponse(fd, response, cmd);
+    if (result < 0 || response[0] == '\0')
+        return false;
+
+    int degrees = 0, minutes = 0;
+    double seconds = 0.0;
+    if (sscanf(response, "%d%*c%d:%lf", &degrees, &minutes, &seconds) < 2)
+    {
+        LOGF_DEBUG("Unable to parse OnStep site coordinate response for %s: <%s>", cmd, response);
+        return false;
+    }
+
+    const double sign = degrees < 0 ? -1.0 : 1.0;
+    double coordinate = std::abs(degrees) + std::abs(minutes) / 60.0 + std::fabs(seconds) / 3600.0;
+    coordinate *= sign;
+
+    // OnStep follows Meade LX200 longitude convention: east is negative. INDI
+    // geographic longitude is cartographic: east is positive.
+    *value = longitude ? -coordinate : coordinate;
+    return true;
+}
+
+bool LX200_OnStepX::readOnStepSiteCoordinate(int fd, const char *highPrecisionCmd, const char *fallbackCmd,
+        double *value, bool longitude)
+{
+    if (getOnStepSiteCoordinate(fd, highPrecisionCmd, value, longitude))
+        return true;
+
+    return getOnStepSiteCoordinate(fd, fallbackCmd, value, longitude);
+}
+
+bool LX200_OnStepX::sendScopeLocation()
+{
+    double latitude = 0.0, longitude = 0.0;
+    char lat_sexagesimal[MAXINDIFORMAT] = {0};
+    char lng_sexagesimal[MAXINDIFORMAT] = {0};
+
+    if (isSimulation())
+    {
+        LocationNP[LOCATION_LATITUDE].setValue(29.5);
+        LocationNP[LOCATION_LONGITUDE].setValue(48.0);
+        LocationNP[LOCATION_ELEVATION].setValue(10);
+        LocationNP.setState(IPS_OK);
+        LocationNP.apply();
+        return true;
+    }
+
+    if (!readOnStepSiteCoordinate(PortFD, ":GtH#", ":Gt#", &latitude, false))
+    {
+        LOG_WARN("Failed to get site latitude from device.");
+        return false;
+    }
+
+    if (!readOnStepSiteCoordinate(PortFD, ":GgH#", ":Gg#", &longitude, true))
+    {
+        LOG_WARN("Failed to get site longitude from device.");
+        return false;
+    }
+
+    LocationNP[LOCATION_LATITUDE].setValue(latitude);
+    LocationNP[LOCATION_LONGITUDE].setValue(longitude);
+    fs_sexa(lat_sexagesimal, latitude, 3, 360000);
+    fs_sexa(lng_sexagesimal, longitude, 4, 360000);
+
+    double elevation = 0.0;
+    char elevation_response[RB_MAX_LEN] = {0};
+    if (getCommandDoubleResponse(PortFD, &elevation, elevation_response, ":Gv#") < 0)
+    {
+        LOG_WARN("Failed to get site elevation from device.");
+    }
+    else
+    {
+        LocationNP[LOCATION_ELEVATION].setValue(elevation);
+    }
+
+    LOGF_INFO("Mount has Latitude %s (%g) Longitude %s (%g) Elevation %g m (Longitude sign in carthography format)",
+              lat_sexagesimal,
+              LocationNP[LOCATION_LATITUDE].getValue(),
+              lng_sexagesimal,
+              LocationNP[LOCATION_LONGITUDE].getValue(),
+              LocationNP[LOCATION_ELEVATION].getValue());
+
+    LocationNP.apply();
+    saveConfig(true, "GEOGRAPHIC_COORD");
+
+    return true;
+}
diff --git a/drivers/telescope/lx200_OnStepX.h b/drivers/telescope/lx200_OnStepX.h
new file mode 100644
index 0000000..cb10eab
--- /dev/null
+++ b/drivers/telescope/lx200_OnStepX.h
@@ -0,0 +1,33 @@
+/*
+    LX200 OnStepX
+
+    PiFinder-focused OnStep driver variant.  It keeps the upstream LX200 OnStep
+    behavior as a base while giving MF PiFinder a stable driver name for local
+    fixes that are not yet suitable for the upstream driver.
+*/
+
+#pragma once
+
+#include "lx200_OnStep.h"
+
+class LX200_OnStepX : public LX200_OnStep
+{
+    public:
+        LX200_OnStepX();
+        const char *getDefaultName() override;
+        bool initProperties() override;
+        bool ISNewNumber(const char *dev, const char *name, double values[], char *names[], int n) override;
+
+    protected:
+        bool updateLocation(double latitude, double longitude, double elevation) override;
+        int setSiteLongitude(int fd, double longitude) override;
+        int setSiteLatitude(int fd, double latitude) override;
+        bool sendScopeLocation() override;
+
+    private:
+        void configureGuideRateProperty();
+        int setSiteElevation(int fd, double elevation);
+        bool getOnStepSiteCoordinate(int fd, const char *cmd, double *value, bool longitude);
+        bool readOnStepSiteCoordinate(int fd, const char *highPrecisionCmd, const char *fallbackCmd, double *value,
+                                      bool longitude);
+};
