{
    // Note that the JSON5 library that we use for configuration supports comments in JSON files.
    //
    // INDI field-debug log config.  Same as logconf_default.json, but raises
    // the INDI mount-control / GoTo-Guide / pointing-coordinate loggers to
    // INFO so recovery slews, guide pulses, guide-rate switches, and
    // tracking-guide state transitions are written to pifinder.log.
    //
    // Switch to this from the web Logs page ("Indi") ONLY while diagnosing
    // mount behaviour in the field -- it writes continuously to the SD card.
    // Switch back to "Default" when done.
    "version": 1,
    "disable_existing_loggers": false, // THIS MUST BE FALSE for logging to work
    "formatters": {
        "default": {
            "format": "%(asctime)s %(processName)s-%(name)s:%(levelname)s:%(message)s"
        }
    },
    "handlers": {
        "console": {
            "class": "logging.StreamHandler",
            "level": "ERROR",
            "formatter": "default",
            "stream": "ext://sys.stdout"
        },
        "null": {
            "class": "logging.NullHandler",
            "level": "ERROR"
        }
    },
    "loggers": {

        //
        /////////////////////////////////////////////////////////////////
        ////// root logger
        //
        "": {
            "level": "ERROR",
            "handlers": ["console"]
            // The file handler is added automatically by code
        },

        /////////////////////////////////////////////////////////////////
        ////// Web Server Subsystem (Flask with Jinja2 i18n)
        "Server": {
            "level": "INFO"
        },
        "Server.Logs": {
            "level": "ERROR"
        },

        /////////////////////////////////////////////////////////////////
        ////// INDI mount control / GoTo-Guide / pointing coordinate
        //
        // Raised to INFO for field diagnosis of disturbance-recovery
        // behaviour: tracking-guide state transitions, recovery sync+GoTo
        // events, guide pulses, and guide-rate switches.
        "MountControl": {
            "level": "INFO"
        },
        "IndiGotoGuideService": {
            "level": "INFO"
        },
        "PointingCoordinateService": {
            "level": "INFO"
        },
        // Which body a GoTo target was identified as, and -- the reason this
        // is here -- the separation of near-misses that were rejected, which
        // is what a systematic coordinate offset looks like.
        "TrackFreqPolicy": {
            "level": "INFO"
        },

        /////////////////////////////////////////////////////////////////
        ////// Flask Framework (used for webserver)
        "waitress": {
            "level": "ERROR"
        },
        "flask": {
            "level": "ERROR"
        },
        "flask.app": {
            "level": "ERROR"
        },

        /////////////////////////////////////////////////////////////////
        ////// Solver
        "Solver": {
            "level": "ERROR"
        },

        /////////////////////////////////////////////////////////////////
        ////// On-disk caches (Hipparcos pickle, catalog composite pickle)
        "Plot": {
            "level": "INFO"
        },
        "Catalog.Cache": {
            "level": "INFO"
        },

        /////////////////////////////////////////////////////////////////
        ////// GPS Subsystem
        "GPS": {
            "level": "WARNING"
        },
        "GPS.parser": {
            "level": "WARNING"
        },
        "GPS.fake": {
            "level": "WARNING"
        },

        /////////////////////////////////////////////////////////////////
        ////// Third party Libraries
        "PIL.PngImagePlugin": {
            "level": "WARNING"
        },
        "tetra3.Tetra3": {
            "level": "WARNING"
        },
        "picamera2.picamera2": {
            "level": "WARNING"
        },
        "grpc": {
            "level": "ERROR",
            "propagate": false,
            "handlers": ["null"]
        },
   }
}
